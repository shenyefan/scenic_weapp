<view class="page-container">
  <t-navbar title="处置任务" leftArrow placeholder />

  <!-- 搜索栏 -->
  <t-sticky offset-top="{{navBarHeight}}">
    <view class="search-bar-wrap">
      <t-button icon="calendar" bind:tap="onDateFilterTap" class="filter-icon-btn{{selectedDate ? ' filter-btn-active' : ''}}" />
      <t-search
        class="search-input"
        value="{{searchKeyword}}"
        placeholder="搜索"
        shape="square"
        action-text=""
        bind:change="onSearchChange"
        bind:clear="onSearchClear"
      />
      <t-button wx:if="{{role == 'admin'}}" theme="primary" icon="add" bind:tap="onAddTap" class="add-btn">派发</t-button>
    </view>
  </t-sticky>

  <!-- 处置状态 Tab -->
  <t-tabs
    value="{{activeTab}}"
    bind:change="onTabChange"
    sticky
    sticky-props="{{ {offsetTop: navBarHeight + 60} }}"
    class="status-tabs"
  >
    <t-tab-panel value="" label="全部" />
    <t-tab-panel value="pending" label="待处置" />
    <t-tab-panel value="in_progress" label="处理中" />
    <t-tab-panel value="completed" label="已完成" />
    <t-tab-panel value="timeout" label="已超时" />
  </t-tabs>

  <!-- 骨架屏 -->
  <view class="skeleton-list" wx:if="{{skeleton}}">
    <view class="skeleton-cell" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
      <view class="skeleton-cell-body">
        <view class="skeleton-cell-title"></view>
        <view class="skeleton-cell-tag-row">
          <view class="skeleton-cell-tag"></view>
        </view>
        <view class="skeleton-cell-line"></view>
        <view class="skeleton-cell-line" style="width:55%;"></view>
      </view>
    </view>
  </view>

  <!-- 列表 -->
  <view wx:elif="{{list.length > 0}}" class="item-group">
    <view
      class="attraction-item"
      wx:for="{{list}}"
      wx:key="id"
      hover-class="attraction-item--hover"
      hover-stay-time="70"
    >
      <view class="attraction-item-body" bind:tap="onItemTap" data-id="{{item.id}}">
        <view class="attraction-item-right">
          <view class="attraction-item-top">
            <text class="attraction-item-name">{{item.attractionsName}}</text>
            <view class="attraction-item-tags">
              <t-tag size="small" theme="{{item.disposalStatusType}}" variant="light">{{item.disposalStatusLabel}}</t-tag>
            </view>
          </view>
          <text class="attraction-item-desc" wx:if="{{item.inspectionDescription}}">异常：{{item.inspectionDescription}}</text>
          <text class="attraction-item-desc" wx:if="{{item.disposalDescription}}">处置：{{item.disposalDescription}}</text>
          <view class="attraction-item-meta">
            <t-icon name="time" size="14px" color="#999" />
            <text class="attraction-item-meta-text">{{item.taskDate || '日期未定'}}</text>
          </view>
        </view>
      </view>
      <!-- 管理员：处置员名称 + 编辑 + 删除 -->
      <t-row wx:if="{{role == 'admin'}}" class="attraction-item-actions" gutter="0" catchtap="stopPropagation">
        <t-col span="10">
          <view class="action-col action-col-inspector">
            <t-icon name="user-1" size="20px" color="#999" />
            <text class="action-inspector-text">{{item.disposerName || '未分配'}}</text>
          </view>
        </t-col>
        <t-col span="7">
          <view class="action-col action-col-btn" catchtap="onEditTap" data-id="{{item.id}}">
            <t-icon name="edit" size="20px" color="#0052d9" />
            <text class="action-btn-text action-edit-text">编辑</text>
          </view>
        </t-col>
        <t-col span="7">
          <view class="action-col action-col-btn action-col-delete" catchtap="onDeleteTap" data-id="{{item.id}}" data-name="{{item.attractionsName}}">
            <t-icon name="delete" size="20px" color="#e34d59" />
            <text class="action-btn-text action-delete-text">删除</text>
          </view>
        </t-col>
      </t-row>
    </view>
    <t-divider content="已加载全部" wx:if="{{!hasMore}}" />
    <view class="load-more-wrap" wx:if="{{loadingMore}}">
      <t-loading theme="circular" size="28px" text="加载更多..." />
    </view>
  </view>

  <!-- 空状态 -->
  <t-empty wx:elif="{{!skeleton}}" description="暂无处置任务" />

  <!-- 日期筛选 picker -->
  <t-picker
    visible="{{showDatePicker}}"
    value="{{datePickerValue}}"
    title="选择日期"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bindchange="onDatePickerConfirm"
    bindcancel="onDatePickerCancel"
  >
    <t-picker-item options="{{dateYearOptions}}" />
    <t-picker-item options="{{dateMonthOptions}}" />
    <t-picker-item options="{{dateDayOptions}}" />
  </t-picker>

  <!-- 删除确认弹窗 -->
  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="确定要删除「{{deleteTargetName}}」的处置任务吗？此操作不可恢复。"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onDeleteCancel"
  />

  <t-toast id="t-toast" />
</view>
