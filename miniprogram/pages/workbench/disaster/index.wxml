<view class="page-container">
  <t-navbar title="灾害信息" leftArrow placeholder z-index="100"/>

  <view class="search-bar-wrap">
    <t-button icon="calendar" bind:tap="onDateFilterTap" class="filter-icon-btn{{selectedDate ? ' filter-btn-active' : ''}}" />
    <t-search
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索灾害标题/描述"
      shape="square"
      action-text=""
      bind:change="onSearchChange"
      bind:clear="onSearchClear"
    />
    <view wx:if="{{role == 'admin'}}" class="action-btn-wrap">
      <t-button theme="primary" bind:tap="onAddTap" icon="add"></t-button>
    </view>
  </view>

  <view class="skeleton-list" wx:if="{{skeleton}}">
    <view class="skeleton-cell" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
      <view class="skeleton-cell-body">
        <view class="skeleton-cell-title"></view>
        <view class="skeleton-cell-tag-row"><view class="skeleton-cell-tag"></view></view>
        <view class="skeleton-cell-line"></view>
        <view class="skeleton-cell-line" style="width:85%;"></view>
        <view class="skeleton-cell-line" style="width:60%;"></view>
      </view>
    </view>
  </view>

  <view wx:elif="{{list.length > 0}}" class="item-group">
    <view class="info-item" wx:for="{{list}}" wx:key="id">
      <view class="info-item-body">
        <view class="info-item-top">
          <text class="info-item-name">{{item.title}}</text>
          <t-tag size="small" theme="{{item.severityTheme}}" variant="light">{{item.severity}}</t-tag>
        </view>
        <text class="info-item-desc">{{item.description}}</text>
        <view class="info-item-meta">
          <t-icon name="time" size="14px" color="#999" />
          <text class="info-item-meta-text">开始时间：{{item.startTime}}</text>
        </view>
        <view class="info-item-meta">
          <t-icon name="check-circle" size="14px" color="#999" />
          <text class="info-item-meta-text">结束时间：{{item.endTime}}</text>
        </view>
      </view>
      <t-row wx:if="{{role == 'admin'}}" class="info-item-actions" gutter="0" catchtap="stopPropagation">
        <t-col span="12">
          <view class="action-col action-col-btn" style="border-left:none;" catchtap="onEditTap" data-id="{{item.id}}">
            <t-icon name="edit" size="20px" color="#0052d9" />
            <text class="action-btn-text action-edit-text">编辑</text>
          </view>
        </t-col>
        <t-col span="12">
          <view class="action-col action-col-btn action-col-delete" catchtap="onDeleteTap" data-id="{{item.id}}" data-name="{{item.title}}">
            <t-icon name="delete" size="20px" color="#e34d59" />
            <text class="action-btn-text action-delete-text">删除</text>
          </view>
        </t-col>
      </t-row>
    </view>
    <t-divider content="已加载全部" wx:if="{{!hasMore}}" />
    <view class="load-more-wrap" wx:if="{{loadingMore}}">
      <t-loading theme="circular" size="28px" text="加载更多..." />
    </view>
  </view>

  <t-empty wx:elif="{{!skeleton}}" description="暂无灾害信息" />

  <t-date-time-picker
    visible="{{showDatePicker}}"
    value="{{datePickerValue}}"
    title="选择日期"
    mode="date"
    format="YYYY-MM-DD"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bind:confirm="onDatePickerConfirm"
    bindcancel="onDatePickerCancel"
  />

  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="确定要删除灾害信息「{{deleteTargetName}}」吗？此操作不可恢复。"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onDeleteCancel"
  />

  <t-toast id="t-toast" />
</view>
