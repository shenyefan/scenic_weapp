<view class="page-container">
  <t-navbar title="巡查任务" leftArrow placeholder z-index='100'/>

  <!-- 搜索栏 -->
  <view class="search-bar-wrap">
      <t-button icon="calendar" bind:tap="onDateFilterTap" class="filter-icon-btn{{selectedDate ? ' filter-btn-active' : ''}}" />
      <t-button icon="filter-2" bind:tap="onAbnormalFilterTap" class="filter-icon-btn{{selectedAbnormalStatus ? ' filter-btn-active' : ''}}" />
      <t-search
        class="search-input"
        value="{{searchKeyword}}"
        placeholder="搜索"
        shape="square"
        action-text=""
        bind:change="onSearchChange"
        bind:clear="onSearchClear"
      />
      <t-button wx:if="{{role == 'admin'}}" theme="primary" icon="add" bind:tap="onAddTap" class="add-btn">新增</t-button>
    </view>

  <!-- 任务状态 Tab -->
  <t-tabs
    value="{{activeTab}}"
    bind:change="onTabChange"
    sticky
    sticky-props="{{ {offsetTop: navBarHeight} }}"
    class="status-tabs"
  >
    <t-tab-panel value="" label="全部" />
    <t-tab-panel value="in_progress" label="巡查中" />
    <t-tab-panel value="waiting_disposal" label="待处置" />
    <t-tab-panel value="completed" label="已完成" />
    <t-tab-panel value="timeout" label="已超时" />
  </t-tabs>

  <!-- 骨架屏 -->
  <view class="skeleton-list" wx:if="{{skeleton}}">
    <view class="skeleton-cell" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
      <view class="skeleton-cell-body">
        <view class="skeleton-cell-title"></view>
        <view class="skeleton-cell-tag-row">
          <view class="skeleton-cell-tag"></view>
          <view class="skeleton-cell-tag"></view>
        </view>
        <view class="skeleton-cell-line"></view>
      </view>
    </view>
  </view>

  <!-- 列表 -->
  <view wx:elif="{{list.length > 0}}" class="item-group">
    <view
      class="attraction-item"
      wx:for="{{list}}"
      wx:key="id"
      hover-class="attraction-item--hover"
      hover-stay-time="70"
    >
      <view class="attraction-item-body" bind:tap="onItemTap" data-id="{{item.id}}">
        <view class="attraction-item-right">
          <view class="attraction-item-top">
            <text class="attraction-item-name">{{item.attractionsName}}</text>
            <view class="attraction-item-tags">
              <t-tag size="small" theme="{{item.taskStatusType}}" variant="light">{{item.taskStatusLabel}}</t-tag>
              <t-tag size="small" theme="{{item.abnormalStatusType}}" variant="light">{{item.abnormalStatusLabel}}</t-tag>
            </view>
          </view>
          <text class="attraction-item-desc" wx:if="{{item.inspectionDescription}}">{{item.inspectionDescription}}</text>
          <view class="attraction-item-meta">
            <t-icon name="time" size="14px" color="#999" />
            <text class="attraction-item-meta-text">{{item.taskDate || '日期未定'}}</text>
          </view>
        </view>
      </view>
      <!-- 管理员：巡查员名称 + 编辑 + 删除 -->
      <t-row wx:if="{{role == 'admin'}}" class="attraction-item-actions" gutter="0" catchtap="stopPropagation">
        <t-col span="10">
          <view class="action-col action-col-inspector">
            <t-icon name="user-1" size="20px" color="#999" />
            <text class="action-inspector-text">{{item.inspectorName || '未分配'}}</text>
          </view>
        </t-col>
        <t-col span="7">
          <view class="action-col action-col-btn" catchtap="onEditTap" data-id="{{item.id}}">
            <t-icon name="edit" size="20px" color="#0052d9" />
            <text class="action-btn-text action-edit-text">编辑</text>
          </view>
        </t-col>
        <t-col span="7">
          <view class="action-col action-col-btn action-col-delete" catchtap="onDeleteTap" data-id="{{item.id}}" data-name="{{item.attractionsName}} - {{item.taskDate}}">
            <t-icon name="delete" size="20px" color="#e34d59" />
            <text class="action-btn-text action-delete-text">删除</text>
          </view>
        </t-col>
      </t-row>
      <!-- 巡查员 + 巡查中：正常 / 异常 / 编辑 -->
      <t-row wx:elif="{{role == 'inspector' && item.taskStatus == 'in_progress'}}" class="attraction-item-actions" gutter="0" catchtap="stopPropagation">
        <t-col span="8">
          <view class="action-col action-col-btn" style="border-left:none;" catchtap="onNormalTap" data-id="{{item.id}}">
            <t-icon name="check-circle" size="20px" color="#00a870" />
            <text class="action-btn-text action-normal-text">正常</text>
          </view>
        </t-col>
        <t-col span="8">
          <view class="action-col action-col-btn" catchtap="onAbnormalTap" data-id="{{item.id}}">
            <t-icon name="error-circle" size="20px" color="#e8a000" />
            <text class="action-btn-text action-abnormal-text">异常</text>
          </view>
        </t-col>
        <t-col span="8">
          <view class="action-col action-col-btn" catchtap="onEditTap" data-id="{{item.id}}">
            <t-icon name="edit" size="20px" color="#0052d9" />
            <text class="action-btn-text action-edit-text">编辑</text>
          </view>
        </t-col>
      </t-row>
      <!-- 巡查员 + 其他状态：编辑 + 删除 -->
      <t-row wx:elif="{{role == 'inspector'}}" class="attraction-item-actions" gutter="0" catchtap="stopPropagation">
        <t-col span="12">
          <view class="action-col action-col-btn" style="border-left:none;" catchtap="onEditTap" data-id="{{item.id}}">
            <t-icon name="edit" size="20px" color="#0052d9" />
            <text class="action-btn-text action-edit-text">编辑</text>
          </view>
        </t-col>
        <t-col span="12">
          <view class="action-col action-col-btn action-col-delete" catchtap="onDeleteTap" data-id="{{item.id}}" data-name="{{item.attractionsName}} - {{item.taskDate}}">
            <t-icon name="delete" size="20px" color="#e34d59" />
            <text class="action-btn-text action-delete-text">删除</text>
          </view>
        </t-col>
      </t-row>
    </view>
    <t-divider content="已加载全部" wx:if="{{!hasMore}}" />
    <view class="load-more-wrap" wx:if="{{loadingMore}}">
      <t-loading theme="circular" size="28px" text="加载更多..." />
    </view>
  </view>

  <!-- 空状态 -->
  <t-empty wx:elif="{{!skeleton}}" description="暂无巡查任务" />

  <!-- 日期筛选 picker -->
  <t-date-time-picker
    visible="{{showDatePicker}}"
    value="{{datePickerValue}}"
    title="选择日期"
    mode="date"
    format="YYYY-MM-DD"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bind:confirm="onDatePickerConfirm"
    bindcancel="onDatePickerCancel"
  />

  <!-- 异常状态 picker -->
  <t-picker
    visible="{{showAbnormalPicker}}"
    value="{{abnormalPickerValue}}"
    title="异常状态"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bindchange="onAbnormalPickerConfirm"
    bindcancel="onAbnormalPickerCancel"
  >
    <t-picker-item options="{{abnormalStatusOptions}}" />
  </t-picker>

  <!-- 删除确认弹窗 -->
  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="确定要删除「{{deleteTargetName}}」的巡查任务吗？此操作不可恢复。"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onDeleteCancel"
  />

  <!-- 标记正常确认弹窗 -->
  <t-dialog
    visible="{{showNormalDialog}}"
    title="确认操作"
    content="确认将此巡查任务标记为正常完成吗？"
    confirm-btn="确认"
    cancel-btn="取消"
    bind:confirm="onNormalConfirm"
    bind:cancel="onNormalCancel"
  />

  <t-toast id="t-toast" />
</view>
