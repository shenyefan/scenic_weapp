<view class="inspection-page">
	<map
		id="inspection-map"
		class="full-map"
		latitude="{{latitude}}"
		longitude="{{longitude}}"
		markers="{{markers}}"
		polyline="{{polyline}}"
		scale="{{scale}}"
		show-location
		enable-satellite="{{satellite}}"
		enable-3D
		show-compass="{{false}}"
		show-scale="{{false}}"
	/>

	<t-navbar title="巡查检查" leftArrow placeholder class="inspection-navbar" />

	<view class="map-wrap">
		<view class="loading-overlay" wx:if="{{loading}}">
			<t-loading theme="circular" size="40px" text="加载中..." />
		</view>

		<view class="tool-stack tool-stack--left" wx:if="{{!loading}}" style="top: {{toolStackTop}};">
			<view class="tool-btn" bind:tap="onFitTap">
				<t-icon name="home" size="36rpx" color="#0052d9" />
			</view>
			<view class="tool-btn" bind:tap="onLocateTap">
				<t-icon name="location" size="36rpx" color="#0052d9" />
			</view>
			<view class="tool-btn" bind:tap="onToggleSatellite">
				<t-icon name="layers" size="36rpx" color="#0052d9" />
			</view>
			<view class="tool-btn" bind:tap="onZoomInTap">
				<t-icon name="add" size="36rpx" color="#0052d9" />
			</view>
			<view class="tool-btn" bind:tap="onZoomOutTap">
				<t-icon name="minus" size="36rpx" color="#0052d9" />
			</view>
		</view>

		<view class="overlay-bottom">
			<view class="inspection-card">
				<view
					class="inspection-action-btn inspection-action-btn--{{actionType}}{{actionLoading ? ' inspection-action-btn--loading' : ''}}"
					hover-class="inspection-action-btn--pressed"
					hover-stay-time="80"
					bind:tap="onActionTap"
				>
					<t-loading wx:if="{{actionLoading}}" theme="circular" size="40rpx" color="#fff" />
					<block wx:else>
						<t-icon name="{{actionIcon}}" size="44rpx" color="#fff" />
						<text class="inspection-action-label">{{actionLabel}}</text>
					</block>
				</view>

				<view class="inspection-card-main">
					<view class="inspection-status-row">
						<view class="status-pill status-pill--{{status}}">{{statusLabel}}</view>
						<text class="sync-text">{{syncText}}</text>
					</view>

					<view class="inspection-metrics">
						<view class="inspection-metric inspection-metric--primary">
							<text class="inspection-metric-label">巡查时长</text>
							<text class="inspection-metric-value inspection-metric-value--large">{{durationText}}</text>
						</view>
						<view class="inspection-metric-row">
              <view class="inspection-metric inspection-metric--half">
								<text class="inspection-metric-label">开始时间</text>
								<text class="inspection-metric-value">{{startedAtText}}</text>
							</view>
							<view class="inspection-metric inspection-metric--half">
								<text class="inspection-metric-label">巡查距离</text>
								<text class="inspection-metric-value">{{distanceText}}</text>
							</view>

						</view>
						<text class="inspection-hint">{{hintText}}</text>
					</view>
				</view>
			</view>

			<view class="history-btn" bind:tap="onTrackHistoryTap" hover-class="history-btn--pressed" hover-stay-time="70">
				<t-icon name="time" size="32rpx" color="#0052d9" />
				<text class="history-btn-text">查看巡查轨迹记录</text>
				<t-icon name="chevron-right" size="28rpx" color="#a6b7cc" />
			</view>
		</view>
	</view>

	<t-toast id="t-toast" />
  <inspection-fab />
</view>