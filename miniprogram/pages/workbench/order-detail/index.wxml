<view class="page-container">
  <t-navbar title="订单详情" leftArrow placeholder z-index="100"/>

  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="skeleton-hero"></view>
    <view class="skeleton-section-header"></view>
    <view class="form-group">
      <view class="skeleton-cell-row" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-block skeleton-cell-label"></view>
        <view class="skeleton-block skeleton-cell-value"></view>
      </view>
    </view>
    <view class="skeleton-section-header"></view>
    <view class="form-group">
      <view class="skeleton-cell-row" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-block skeleton-cell-label"></view>
        <view class="skeleton-block skeleton-cell-value"></view>
      </view>
    </view>
  </block>

  <block wx:elif="{{detail}}">
    <!-- 状态横幅 + 二维码 -->
    <view class="status-hero" style="background:{{detail.statusBgColor}};">
      <view class="status-hero-top">
        <t-icon name="{{detail.statusIcon}}" size="24px" color="{{detail.statusColor}}" />
        <text class="status-hero-label" style="color:{{detail.statusColor}};">{{detail.statusLabel}}</text>
      </view>
      <view class="status-hero-qr">
        <t-qrcode
          value="{{detail.id}}"
          size="{{200}}"
          level="M"
          status="active"
          color="{{detail.qrColor}}"
          bgColor="#ffffff"
        />
      </view>
      <text class="status-hero-id">{{detail.id}}</text>
    </view>

    <!-- 票务明细 -->
    <view class="section-header">票务明细</view>
    <view class="form-group">
      <view wx:if="{{detail.orderItems.length > 0}}">
        <view class="ticket-item" wx:for="{{detail.orderItems}}" wx:key="ticketName">
          <text class="ticket-name">{{item.ticketName}}</text>
          <view class="ticket-item-row2">
            <text class="ticket-meta">¥{{item.unitPrice}} × {{item.quantity}}</text>
            <text class="ticket-subtotal">¥{{item.subtotal}}</text>
          </view>
        </view>
        <view class="ticket-total-row">
          <text class="ticket-total-label">共 {{detail.totalQty}} 张</text>
          <text class="ticket-total-price">合计 ¥{{detail.totalPrice}}</text>
        </view>
      </view>
      <view wx:else class="empty-tickets">
        <text>暂无票务明细</text>
      </view>
    </view>

    <!-- 联系人信息 -->
    <view class="section-header">联系人信息</view>
    <view class="form-group">
      <t-cell title="联系人" note="{{detail.contactName}}" />
      <t-cell title="联系电话" note="{{detail.contactPhone || '暂无'}}" />
      <t-cell title="游览日期" note="{{detail.visitDate || '—'}}" wx:if="{{detail.visitDate}}" />
    </view>

    <!-- 订单信息 -->
    <view class="section-header">订单信息</view>
    <view class="form-group">
      <t-cell title="订单金额" note="¥{{detail.totalPrice}}" t-class-note="price-note" />
      <t-cell title="下单用户" note="{{detail.userName || '—'}}" wx:if="{{detail.userName}}" />
      <t-cell title="用户手机" note="{{detail.userPhone || '—'}}" wx:if="{{detail.userPhone}}" />
      <t-cell title="下单时间" note="{{detail.createTime || '—'}}" />
    </view>

    <!-- 编辑按钮（管理员） -->
    <view class="detail-footer" wx:if="{{role == 'admin'}}">
      <t-button theme="primary" size="large" icon="edit" bind:tap="onEditTap" style="width:100%;">编辑订单</t-button>
    </view>
  </block>

  <t-toast id="t-toast" />
  <inspection-fab />
</view>

