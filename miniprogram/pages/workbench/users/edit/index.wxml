<view class="page-container">
  <t-navbar title="编辑用户" leftArrow placeholder z-index="100"/>

  <!-- 骨架屏 -->
  <block wx:if="{{initLoading}}">
    <view class="skeleton-section-header"></view>
    <view class="form-group">
      <view class="skeleton-cell-row" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-block skeleton-cell-label"></view>
        <view class="skeleton-block skeleton-cell-value"></view>
      </view>
    </view>
    <view class="skeleton-section-header"></view>
    <view class="form-group">
      <view class="skeleton-cell-row" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-block skeleton-cell-label"></view>
        <view class="skeleton-block skeleton-cell-value"></view>
      </view>
    </view>
  </block>

  <block wx:else>
    <!-- 头像 -->
    <view class="section-header">头像</view>
    <view class="form-group">
      <button
        class="edit-avatar-cell"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >
        <view class="edit-avatar-cell__label">头像</view>
        <view class="edit-avatar-cell__right">
          <block wx:if="{{avatarUploading}}">
            <t-loading theme="circular" size="40rpx" />
          </block>
          <block wx:else>
            <t-avatar wx:if="{{form.userAvatar}}" image="{{form.userAvatar}}" size="80rpx" />
            <t-avatar wx:else icon="user" size="80rpx" />
          </block>
          <t-icon name="chevron-right" size="36rpx" color="#bbb" />
        </view>
      </button>
    </view>

    <!-- 基本信息 -->
    <view class="section-header">基本信息</view>
    <view class="form-group">
      <t-input
        label="昵称"
        align="right"
        value="{{form.userNickname}}"
        placeholder="请输入昵称（必填）"
        maxlength="32"
        bind:change="onNicknameChange"
      />
      <t-input
        label="个人简介"
        align="right"
        value="{{form.userProfile}}"
        placeholder="请输入个人简介"
        maxlength="512"
        bind:change="onProfileChange"
      />
      <t-cell
        title="性别"
        note="{{form.genderLabel}}"
        arrow
        hover
        bind:click="onGenderPickerTap"
      />
    </view>

    <!-- 账号设置 -->
    <view class="section-header">账号设置</view>
    <view class="form-group">
      <t-input
        label="登录账号"
        align="right"
        value="{{form.userAccount}}"
        placeholder="请输入登录账号（必填，4-32位）"
        maxlength="32"
        bind:change="onAccountChange"
      />
      <t-input
        label="手机号"
        align="right"
        value="{{form.userPhone}}"
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        bind:change="onPhoneChange"
      />
      <t-input
        label="邮箱"
        align="right"
        value="{{form.userEmail}}"
        placeholder="请输入邮箱地址"
        maxlength="64"
        bind:change="onEmailChange"
      />
      <t-input
        label="新密码"
        align="right"
        value="{{form.userPassword}}"
        placeholder="留空则不修改密码（8-32位）"
        password
        maxlength="32"
        bind:change="onPasswordChange"
      />
    </view>

    <!-- 权限设置 -->
    <view class="section-header">权限设置</view>
    <view class="form-group">
      <t-cell
        title="用户角色"
        note="{{form.roleLabel}}"
        arrow
        hover
        bind:click="onRolePickerTap"
      />
    </view>

    <!-- 提交按钮 -->
    <view class="form-footer">
      <t-button
        theme="primary"
        size="large"
        style="width:100%;"
        loading="{{submitting}}"
        bind:tap="onSubmit"
      >保存修改</t-button>
    </view>
  </block>

  <!-- 角色选择器 -->
  <t-picker
    visible="{{showRolePicker}}"
    title="选择角色"
    bind:cancel="onRolePickerCancel"
    bind:confirm="onRolePickerConfirm"
  >
    <t-picker-item options="{{roleOptions}}" value="{{rolePickerValue[0]}}" />
  </t-picker>

  <!-- 性别选择器 -->
  <t-picker
    visible="{{showGenderPicker}}"
    title="选择性别"
    bind:cancel="onGenderPickerCancel"
    bind:confirm="onGenderPickerConfirm"
  >
    <t-picker-item options="{{genderOptions}}" value="{{genderPickerValue[0]}}" />
  </t-picker>

  <t-toast id="t-toast" />
</view>
