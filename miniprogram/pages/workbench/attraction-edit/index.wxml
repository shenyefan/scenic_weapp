<view class="page-container">
  <t-navbar title="{{isEdit ? '编辑景点' : '新建景点'}}" leftArrow placeholder z-index="100"/>

  <!-- 骨架屏 -->
  <block wx:if="{{initLoading}}">
    <view class="skeleton-section-header"></view>
    <view class="form-group">
      <view class="skeleton-cell-row" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-block skeleton-cell-label"></view>
        <view class="skeleton-block skeleton-cell-value"></view>
      </view>
    </view>
    <view class="skeleton-section-header" style="margin-top:24rpx;"></view>
    <view class="form-group">
      <view class="skeleton-cell-row">
        <view class="skeleton-block skeleton-cell-label"></view>
        <view class="skeleton-block skeleton-cell-value"></view>
      </view>
    </view>
    <view class="skeleton-section-header" style="margin-top:24rpx;"></view>
    <view class="form-group skeleton-media-block"></view>
  </block>

  <block wx:else>
    <!-- 基本信息 -->
    <view class="section-header">基本信息</view>
    <view class="form-group">
      <t-input
        label="景点名称"
        align="right"
        value="{{form.attractionsName}}"
        placeholder="请输入景点名称（必填）"
        maxlength="50"
        bind:change="onNameChange"
      />
      <t-cell title="景点类型" arrow hover bind:click="onTypePickerTap">
        <view slot="note" class="cell-note">
          <view wx:if="{{form.typeNames.length > 0}}" class="cell-tags">
            <t-tag
              wx:for="{{form.typeNames}}"
              wx:key="*this"
              wx:for-item="tag"
              size="small"
              theme="primary"
              variant="light"
            >{{tag}}</t-tag>
          </view>
          <text wx:else class="cell-placeholder">请选择类型</text>
        </view>
      </t-cell>
      <t-cell
        title="巡查员"
        note="{{form.inspectorName || '请选择巡查员'}}"
        arrow
        hover
        bind:click="onInspectorPickerTap"
        t-class-note="{{form.inspectorName ? '' : 'cell-note-placeholder'}}"
      />
    </view>

    <!-- 景点描述 -->
    <view class="section-header">景点描述</view>
    <view class="form-group">
      <t-textarea
        value="{{form.attractionsDescription}}"
        placeholder="请输入景点描述（可选）"
        maxlength="2000"
        indicator
        autosize
        bind:change="onDescChange"
        class="desc-textarea"
      />
    </view>

    <!-- 地理坐标 -->
    <view class="section-header">地理坐标</view>
    <view class="form-group">
      <t-input
        label="经度"
        align="right"
        value="{{form.lngStr}}"
        placeholder="如：113.94"
        type="digit"
        bind:change="onLngChange"
      />
      <t-input
        label="纬度"
        align="right"
        value="{{form.latStr}}"
        placeholder="如：22.52"
        type="digit"
        bind:change="onLatChange"
      />
      <view class="location-action-row">
        <t-button
          theme="primary"
          variant="outline"
          size="small"
          loading="{{locating}}"
          bind:tap="onFillCurrentLocationTap"
        >获取当前位置</t-button>
      </view>
    </view>

    <!-- 景点图片 -->
    <view class="section-header">景点图片</view>
    <view class="form-group media-section">
      <media-uploader
        src="{{form.attractionsImage}}"
        folder="attraction"
        mediaType="image"
        hint="支持 JPG/PNG，建议比例 16:9，大小不超过 5MB"
        emptyText="点击上传图片"
        bind:change="onImageChange"
      />
    </view>

    <!-- 景点视频 -->
    <view class="section-header">景点视频</view>
    <view class="form-group media-section">
      <media-uploader
        src="{{form.attractionsVideo}}"
        folder="attraction"
        mediaType="video"
        hint="支持 MP4，时长建议不超过 3 分钟，大小不超过 50MB"
        emptyText="点击上传视频"
        bind:change="onVideoChange"
      />
    </view>

    <!-- 提交按钮 -->
    <view class="form-footer">
      <t-button
        theme="primary"
        size="large"
        style="width:100%;"
        loading="{{submitting}}"
        bind:tap="onSubmit"
      >{{isEdit ? '保存修改' : '提交'}}</t-button>
    </view>
  </block>

  <!-- 景点类型多选弹窗 -->
  <multi-select-picker
    visible="{{showTypePicker}}"
    title="选择景点类型"
    options="{{typeOptions}}"
    value="{{form.typeIds}}"
    bind:confirm="onTypePickerConfirm"
    bind:cancel="onTypePickerCancel"
  />

  <!-- 巡查员 picker -->
  <t-picker
    visible="{{showInspectorPicker}}"
    value="{{inspectorPickerValue}}"
    title="选择巡查员"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bindchange="onInspectorPickerConfirm"
    bindcancel="onInspectorPickerCancel"
  >
    <t-picker-item options="{{inspectorPickerOptions}}" />
  </t-picker>

  <t-toast id="t-toast" />
</view>
