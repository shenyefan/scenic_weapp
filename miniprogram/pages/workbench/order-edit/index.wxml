<view class="page-container">
  <t-navbar title="编辑订单" leftArrow placeholder z-index="100"/>

  <!-- 骨架屏 -->
  <block wx:if="{{initLoading}}">
    <view class="skeleton-section-header"></view>
    <view class="form-group">
      <view class="skeleton-cell-row" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
        <view class="skeleton-block skeleton-cell-label"></view>
        <view class="skeleton-block skeleton-cell-value"></view>
      </view>
    </view>
  </block>

  <block wx:else>
    <!-- 联系人信息 -->
    <view class="section-header">联系人信息</view>
    <view class="form-group">
      <t-input
        label="联系人姓名"
        align="right"
        value="{{form.contactName}}"
        placeholder="请输入联系人姓名（必填）"
        maxlength="32"
        bind:change="onContactNameChange"
      />
      <t-input
        label="联系人电话"
        align="right"
        value="{{form.contactPhone}}"
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        bind:change="onContactPhoneChange"
      />
    </view>

    <!-- 订单信息 -->
    <view class="section-header">订单信息</view>
    <view class="form-group">
      <t-cell
        title="游览日期"
        note="{{form.visitDate || '请选择游览日期'}}"
        arrow
        hover
        bind:click="onDatePickerTap"
        t-class-note="{{form.visitDate ? '' : 'cell-note-placeholder'}}"
      />
      <t-cell
        title="订单状态"
        note="{{form.statusLabel || '请选择状态'}}"
        arrow
        hover
        bind:click="onStatusPickerTap"
        t-class-note="{{form.statusLabel ? '' : 'cell-note-placeholder'}}"
      />
      <t-input
        label="订单金额"
        align="right"
        value="{{form.totalPriceStr}}"
        placeholder="请输入金额（元）"
        type="digit"
        bind:change="onTotalPriceChange"
      />
    </view>

    <!-- 票务明细（只读） -->
    <view class="section-header">票务明细</view>
    <view class="form-group">
      <view wx:if="{{orderItems.length > 0}}">
        <view class="ticket-item" wx:for="{{orderItems}}" wx:key="ticketName">
          <text class="ticket-name">{{item.ticketName}}</text>
          <view class="ticket-item-row2">
            <text class="ticket-meta">¥{{item.unitPrice}} × {{item.quantity}}</text>
            <text class="ticket-subtotal">¥{{item.subtotal}}</text>
          </view>
        </view>
        <view class="ticket-total-row">
          <text class="ticket-total-label">共 {{totalQty}} 张</text>
          <text class="ticket-total-price">合计 ¥{{form.totalPriceStr}}</text>
        </view>
      </view>
      <view wx:else class="empty-tickets">
        <text>暂无订单项明细</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="form-footer">
      <t-button
        theme="primary"
        size="large"
        style="width:100%;"
        loading="{{submitting}}"
        bind:tap="onSubmit"
      >保存修改</t-button>
    </view>
  </block>

  <!-- 游览日期 picker -->
  <t-picker
    visible="{{showDatePicker}}"
    value="{{datePickerValue}}"
    title="选择游览日期"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bindchange="onDatePickerConfirm"
    bindcancel="onDatePickerCancel"
  >
    <t-picker-item options="{{dateYearOptions}}" />
    <t-picker-item options="{{dateMonthOptions}}" />
    <t-picker-item options="{{dateDayOptions}}" />
  </t-picker>

  <!-- 订单状态 picker -->
  <t-picker
    visible="{{showStatusPicker}}"
    value="{{statusPickerValue}}"
    title="选择订单状态"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bindchange="onStatusPickerConfirm"
    bindcancel="onStatusPickerCancel"
  >
    <t-picker-item options="{{statusPickerOptions}}" />
  </t-picker>

  <t-toast id="t-toast" />
</view>
