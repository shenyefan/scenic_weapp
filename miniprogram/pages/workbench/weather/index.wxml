<view class="page-container">
  <t-navbar title="天气信息{{isInspectionRunning ? ' · 巡查中' : ''}}" leftArrow placeholder z-index="100"/>

  <view class="search-bar-wrap">
    <t-button icon="calendar" bind:tap="onDateFilterTap" class="filter-icon-btn{{selectedDate ? ' filter-btn-active' : ''}}" />
    <t-search
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索"
      shape="square"
      action-text=""
      bind:change="onSearchChange"
      bind:clear="onSearchClear"
    />
    <view wx:if="{{role == 'admin'}}" class="action-btn-wrap">
      <t-button theme="primary" bind:tap="onAddTap" icon="add"></t-button>
    </view>
  </view>

  <view class="skeleton-list" wx:if="{{skeleton}}">
    <view class="skeleton-cell" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
      <view class="skeleton-cell-body">
        <view class="skeleton-cell-title"></view>
        <view class="skeleton-cell-line" style="width:30%;"></view>
        <view class="skeleton-grid">
          <view class="skeleton-grid-item" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view>
        </view>
      </view>
    </view>
  </view>

  <view wx:elif="{{list.length > 0}}" class="item-group">
    <view class="info-item" wx:for="{{list}}" wx:key="id">
      <view class="info-item-body">
        <view class="info-item-top">
          <text class="info-item-name">{{item.weatherTime}}</text>
        </view>

        <view class="weather-metrics-grid">
          <view class="weather-metric-cell">
            <text class="weather-metric-label">温度</text>
            <text class="weather-metric-value">{{item.tempText}}</text>
          </view>
          <view class="weather-metric-cell">
            <text class="weather-metric-label">湿度</text>
            <text class="weather-metric-value">{{item.humidityText}}</text>
          </view>
          <view class="weather-metric-cell">
            <text class="weather-metric-label">风速</text>
            <text class="weather-metric-value">{{item.windSpeedText}}</text>
          </view>
          <view class="weather-metric-cell">
            <text class="weather-metric-label">风向角</text>
            <text class="weather-metric-value">{{item.windDegText}}</text>
          </view>
          <view class="weather-metric-cell">
            <text class="weather-metric-label">气压</text>
            <text class="weather-metric-value">{{item.pressureText}}</text>
          </view>
          <view class="weather-metric-cell">
            <text class="weather-metric-label">降水量</text>
            <text class="weather-metric-value">{{item.rainText}}</text>
          </view>
        </view>
      </view>
      <t-row wx:if="{{role == 'admin'}}" class="info-item-actions" gutter="0" catchtap="stopPropagation">
        <t-col span="12">
          <view class="action-col action-col-btn" style="border-left:none;" catchtap="onEditTap" data-id="{{item.id}}">
            <t-icon name="edit" size="20px" color="#0052d9" />
            <text class="action-btn-text action-edit-text">编辑</text>
          </view>
        </t-col>
        <t-col span="12">
          <view class="action-col action-col-btn action-col-delete" catchtap="onDeleteTap" data-id="{{item.id}}" data-name="{{item.weatherTime}}">
            <t-icon name="delete" size="20px" color="#e34d59" />
            <text class="action-btn-text action-delete-text">删除</text>
          </view>
        </t-col>
      </t-row>
    </view>
    <t-divider content="已加载全部" wx:if="{{!hasMore}}" />
    <view class="load-more-wrap" wx:if="{{loadingMore}}">
      <t-loading theme="circular" size="28px" text="加载更多..." />
    </view>
  </view>

  <t-empty wx:elif="{{!skeleton}}" description="暂无天气信息" />

  <t-date-time-picker
    visible="{{showDatePicker}}"
    value="{{datePickerValue}}"
    title="选择日期"
    mode="date"
    format="YYYY-MM-DD"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bind:confirm="onDatePickerConfirm"
    bindcancel="onDatePickerCancel"
  />

  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="确定要删除「{{deleteTargetName}}」的天气记录吗？"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onDeleteCancel"
  />

  <t-toast id="t-toast" />
</view>
