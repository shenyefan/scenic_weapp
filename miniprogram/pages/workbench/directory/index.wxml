<view class="page-container">
  <t-navbar title="通讯录" leftArrow placeholder z-index="100"/>

  <!-- 搜索栏 -->
  <view class="search-bar-wrap">
    <t-button icon="filter-2" bind:tap="onRoleFilterTap" class="filter-icon-btn{{selectedRole ? ' filter-btn-active' : ''}}" />
    <t-search
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索"
      shape="square"
      action-text=""
      bind:change="onSearchChange"
      bind:clear="onSearchClear"
    />
  </view>

  <!-- 骨架屏 -->
  <view class="skeleton-list" wx:if="{{skeleton}}">
    <view class="skeleton-cell" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
      <view class="skeleton-cell-avatar"></view>
      <view class="skeleton-cell-body">
        <view class="skeleton-cell-title"></view>
        <view class="skeleton-cell-tag-row"><view class="skeleton-cell-tag"></view></view>
        <view class="skeleton-cell-line"></view>
      </view>
    </view>
  </view>

  <!-- 列表 -->
  <view wx:elif="{{list.length > 0}}" class="item-group">
    <view
      class="directory-item"
      wx:for="{{list}}"
      wx:key="id"
      hover-class="directory-item--hover"
      hover-stay-time="70"
    >
      <view class="directory-item-body">
        <view class="directory-avatar-wrap">
          <t-image wx:if="{{item.avatar}}" class="directory-avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view wx:else class="directory-avatar directory-avatar-placeholder">
            <t-icon name="user-1" size="40rpx" color="#bbb" />
          </view>
        </view>
        <view class="directory-item-right">
          <view class="directory-item-top">
            <text class="directory-item-name">{{item.name}}</text>
            <t-tag size="small" theme="{{item.roleType}}" variant="light">{{item.roleLabel}}</t-tag>
          </view>
          <view class="directory-item-meta">
            <t-icon name="call" size="14px" color="#999" />
            <text class="directory-item-meta-text">{{item.phone || '暂无手机号'}}</text>
          </view>
          <view class="directory-item-meta">
            <t-icon name="mail" size="14px" color="#999" />
            <text class="directory-item-meta-text">{{item.email || '暂无邮箱'}}</text>
          </view>
        </view>
      </view>
      <!-- 手机 + 邮箱操作行 -->
      <t-row class="directory-item-actions" gutter="0" catchtap="stopPropagation">
        <t-col span="12">
          <view
            class="action-col action-col-btn {{item.phone ? '' : 'action-col-disabled'}}" style="border-left:none;"
            catchtap="onPhoneTap"
            data-phone="{{item.phone}}"
          >
            <t-icon name="call" size="20px" color="{{item.phone ? '#0052d9' : '#bbb'}}" />
            <text class="action-btn-text" style="color:{{item.phone ? '#0052d9' : '#bbb'}};">{{item.phone ? '拨打电话' : '暂无手机'}}</text>
          </view>
        </t-col>
        <t-col span="12">
          <view
            class="action-col action-col-btn {{item.email ? '' : 'action-col-disabled'}}"
            catchtap="onEmailCopy"
            data-email="{{item.email}}"
          >
            <t-icon name="mail" size="20px" color="{{item.email ? '#0052d9' : '#bbb'}}" />
            <text class="action-btn-text" style="color:{{item.email ? '#0052d9' : '#bbb'}};">{{item.email ? '复制邮箱' : '暂无邮箱'}}</text>
          </view>
        </t-col>
      </t-row>
    </view>
    <t-divider content="已加载全部" wx:if="{{!hasMore}}" />
    <view class="load-more-wrap" wx:if="{{loadingMore}}">
      <t-loading theme="circular" size="28px" text="加载更多..." />
    </view>
  </view>

  <!-- 空状态 -->
  <t-empty wx:elif="{{!skeleton}}" description="暂无联系人" />

  <!-- 角色 picker -->
  <t-picker
    visible="{{showRolePicker}}"
    value="{{rolePickerValue}}"
    title="筛选角色"
    cancelBtn="取消"
    confirmBtn="确认"
    usingCustomNavbar
    bindchange="onRolePickerConfirm"
    bindcancel="onRolePickerCancel"
  >
    <t-picker-item options="{{roleOptions}}" />
  </t-picker>

  <t-toast id="t-toast" />
  <inspection-fab />
</view>
