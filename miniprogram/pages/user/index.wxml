<wxs module="roleUtils">
var getRoleName = function(role) {
  var roleMap = {
    'user': '游客',
    'admin': '管理员', 
    'inspector': '巡查员',
    'disposer': '处置员',
    'ban': '被封号'
  };
  return roleMap[role] || '普通用户';
};

module.exports.getRoleName = getRoleName;
</wxs>

<view class="user-page">
  <van-notify id="van-notify" />
  <!-- 用户信息区域 -->
  <view class="user-header" bind:tap="onUserInfoClick">
    <view class="user-avatar">
      <van-image
        src="{{userInfo.userAvatar || '/image/user/avatar.png'}}"
        width="120rpx"
        height="120rpx"
        round
      />
    </view>
    <view class="user-info">
      <view class="username">
        {{userInfo.userName || '登录/注册'}}
        <van-icon name="edit" wx:if="{{isLoggedIn}}" />
      </view>
      <view class="user-role">{{isLoggedIn ? roleUtils.getRoleName(userInfo.userRole) : '点击登录'}}</view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="function-list">
    <van-cell
      title="修改密码"
      is-link
      bind:click="changePassword"
    />
    <van-cell
      title="问题反馈"
      is-link
      bind:click="feedback"
    />
    <van-cell
      title="关于"
      is-link
      bind:click="about"
    />
    <van-cell
      title="退出登录"
      is-link
      bind:click="logout"
      wx:if="{{isLoggedIn}}"
      custom-class="logout-cell"
    />
  </view>

  <!-- 修改密码弹窗 -->
  <van-popup
    show="{{ showPasswordModal }}"
    position="bottom"
    round
    closeable
    safe-area-tab-bar
    bind:close="closePasswordModal"
  >
    <view class="password-modal">
      <view class="modal-header">
        <view class="modal-title">修改密码</view>
      </view>
      <view class="modal-content">
        <van-field
          value="{{ newPassword }}"
          type="password"
          placeholder="请输入新密码"
          bind:change="onNewPasswordChange"
        />
        <van-field
          value="{{ confirmPassword }}"
          type="password"
          placeholder="请确认新密码"
          bind:change="onConfirmPasswordChange"
        />
      </view>
      <view class="modal-footer">
        <van-button
          type="primary"
          size="large"
          bind:click="confirmChangePassword"
        >
          确认修改
        </van-button>
      </view>
    </view>
  </van-popup>
</view>