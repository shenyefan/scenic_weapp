<view class="chat-page">
  <t-navbar title="智慧导览" fixed placeholder>
    <view slot="left" class="navbar-left" bindtap="openDrawer">
      <t-icon name="history" size="44rpx" />
    </view>
  </t-navbar>

  <view class="chat-main">
    <t-chat id="chatList" class="chat-content">
      <block wx:for="{{chatList}}" wx:key="chatId">
        <t-chat-message
          chat-id="{{item.chatId}}"
          avatar="{{item.avatar || ''}}"
          name="{{item.name || ''}}"
          datetime="{{item.datetime || ''}}"
          content="{{item.content}}"
          role="{{item.role}}"
          placement="{{item.role === 'user' ? 'right' : 'left'}}"
          status="{{item.status || ''}}"
          bind:message-longpress="showPopover"
        >
        </t-chat-message>
      </block>
    </t-chat>

    <view class="chat-sender-wrap">
      <t-chat-sender
        value="{{value}}"
        loading="{{loading}}"
        disabled="{{disabled}}"
        auto-rise-with-keyboard="{{true}}"
        renderPresets="{{[{ name: 'send', type: 'icon'}]}}"
        bind:send="onSend"
        bind:stop="onStop"
      />
    </view>
  </view>
</view>

<!-- 历史会话抽屉 -->
<t-popup
  visible="{{drawerVisible}}"
  placement="left"
  bind:visible-change="onDrawerVisibleChange"
  close-on-overlay-click
  using-custom-navbar
  class="popup"
>
  <view class="popup-header">
    <text class="popup-title">历史会话</text>
    <view class="popup-new-btn" bindtap="handleNewFromDrawer">
      <t-icon name="add" size="36rpx" />
      <text>新对话</text>
    </view>
  </view>

  <scroll-view class="popup-list" scroll-y enhanced>
    <view wx:if="{{sessionsLoading}}" class="drawer-loading">
      <view class="skeleton-item" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-title"></view>
        <view class="skeleton-time"></view>
      </view>
    </view>

    <view wx:elif="{{sessions.length === 0}}" class="popup-empty">
      <text>暂无历史会话</text>
      <text class="popup-empty-sub">发送消息开始对话</text>
    </view>

    <view wx:else class="session-list">
      <view
        wx:for="{{sessions}}"
        wx:key="sessionId"
        class="session-item {{item.sessionId === sessionId ? 'active' : ''}}"
        bindtap="onSelectSession"
        data-sid="{{item.sessionId}}"
      >
        <view class="session-info">
          <text class="session-title">{{item.title || '未命名会话'}}</text>
          <text class="session-time">{{item._timeLabel || ''}}</text>
        </view>
        <view
          class="session-delete"
          catchtap="onDeleteSession"
          data-sid="{{item.sessionId}}"
        >
          <t-icon name="delete" size="36rpx" color="#e34d59" />
        </view>
      </view>
    </view>
  </scroll-view>
</t-popup>

<t-toast id="t-toast" />