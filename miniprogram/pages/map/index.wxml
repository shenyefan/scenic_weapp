<view class="map-page">
  <map
    id="map-view"
    class="full-map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    markers="{{markers}}"
    polyline="{{polyline}}"
    scale="{{scale}}"
    show-location
    enable-overlooking="{{overlooking}}"
    enable-satellite="{{satellite}}"
    enable-3D
    bindmarkertap="onMarkerTap"
    bindtap="onMapTap"
  />

  <t-navbar title="{{pageTitle}}" leftArrow placeholder class="map-navbar" />

  <view class="search-bar-layer" wx:if="{{type !== 'track'}}">
    <view class="search-bar-wrap">
      <t-button icon="filter-2" bind:tap="onFilterTap" class="filter-btn{{type === 'attraction' && selectedTypeIds.length > 0 ? ' filter-btn-active' : ''}}">
        <view class="filter-badge" wx:if="{{type === 'attraction' && selectedTypeIds.length > 0}}">{{selectedTypeIds.length}}</view>
      </t-button>
      <t-search
        class="search-input"
        value="{{searchKeyword}}"
        placeholder="{{type === 'attraction' ? '搜索景点名称' : '搜索用户名称/地址'}}"
        shape="square"
        action-text=""
        bind:change="onSearchChange"
        bind:clear="onSearchClear"
      />
      <t-button icon="map-route-planning" bind:tap="onRouteTap" class="route-btn" />
    </view>
  </view>

  <view class="track-summary" wx:if="{{type === 'track'}}">
    <view class="track-summary-main">
      <text class="track-summary-title">{{trackTitle}}</text>
      <text class="track-summary-desc">{{trackSummary}}</text>
    </view>
  </view>

  <view class="map-wrap">

    <!-- 加载中 -->
    <view class="loading-overlay" wx:if="{{loading}}">
      <t-loading theme="circular" size="40px" text="加载中..." />
    </view>

    <view class="tool-stack tool-stack--left" wx:if="{{!loading}}" style="top: {{toolStackTop}};">
      <view class="tool-btn" bind:tap="onFitTap">
        <t-icon name="home" size="36rpx" color="#0052d9" />
      </view>
      <view class="tool-btn" bind:tap="onLocateTap">
        <t-icon name="location" size="36rpx" color="#0052d9" />
      </view>
      <view class="tool-btn" bind:tap="onToggleSatellite">
        <t-icon name="layers" size="36rpx" color="#0052d9" />
      </view>
      <view class="tool-btn" bind:tap="onZoomInTap">
        <t-icon name="add" size="36rpx" color="#0052d9" />
      </view>
      <view class="tool-btn" bind:tap="onZoomOutTap">
        <t-icon name="minus" size="36rpx" color="#0052d9" />
      </view>
    </view>

    <!-- 底部详情面板 -->
    <view class="info-panel {{showPanel ? 'info-panel--show' : ''}}">
      <view class="info-panel-inner" wx:if="{{panel}}">
        <view class="info-panel-header">
          <text class="info-panel-title">{{panel.title}}</text>
          <view class="info-panel-close" bind:tap="onPanelClose">
            <t-icon name="close-circle" size="44rpx" color="#bbb" />
          </view>
        </view>

        <view class="info-panel-image-wrap" wx:if="{{panel.image}}">
          <t-image class="info-panel-image" src="{{panel.image}}" mode="aspectFill" />
        </view>

        <view class="info-panel-meta" wx:if="{{panel.tag}}">
          <t-icon name="tag" size="26rpx" color="#999" />
          <text class="info-panel-meta-text">{{panel.tag}}</text>
        </view>

        <view class="info-panel-meta" wx:if="{{panel.detail}}">
          <t-icon name="location" size="26rpx" color="#999" />
          <text class="info-panel-meta-text">{{panel.detail}}</text>
        </view>

        <view class="info-panel-actions" wx:if="{{type === 'attraction'}}">
          <t-button theme="primary" size="small" block bind:tap="onViewDetail">查看详情</t-button>
        </view>
      </view>
    </view>

    <multi-select-picker
      visible="{{showTypeFilter}}"
      title="景点类型"
      options="{{typeOptions}}"
      value="{{selectedTypeIds}}"
      bind:confirm="onFilterConfirm"
      bind:cancel="onFilterCancel"
    />
  </view>

  <t-toast id="t-toast" />
  <inspection-fab />
</view>
