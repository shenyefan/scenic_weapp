<view class="container">
  <van-notify id="van-notify"/>
  
  <!-- banner 区域 -->
  <view class="banner">
    <van-image 
      src="https://dlhqn.moenya.net/static/fj.jpeg" 
      width="100%" 
      height="200" 
      fit="cover"
      custom-class="banner-img"
    />
  </view>

  <!-- 巡查模块 -->
  <view wx:if="{{ loginUser.roleName == '巡查员' || loginUser.roleName == '处置员' }}" class="module-card">
    <view class="module-header">巡查模块</view>
    <van-grid clickable column-num="3" border="{{ false }}" custom-class="function-grid">
      <!-- 巡查检查 -->
      <van-grid-item 
        icon="/image/manage/inspection.png" 
        text="巡查检查" 
        link-type="navigateTo"
        url=""
      />

      <!-- 巡查轨迹 -->
      <van-grid-item 
        icon="/image/manage/track.png" 
        text="巡查轨迹" 
        link-type="navigateTo"
        url=""
      />
      
      <!-- 问题处置 -->
      <van-grid-item 
        wx:if="{{ loginUser.roleName == '处置员' }}"
        icon="/image/manage/disposal.png" 
        text="问题处置" 
        link-type="navigateTo"
        url=""
      />
    </van-grid>

    <!-- 巡查状态控制 -->
    <view wx:if="{{ loginUser.roleName == '巡查员' }}">
      <van-button 
        wx:if="{{ !patrolState }}" 
        type="primary" 
        size="large" 
        icon="play-circle-o"
        bind:click="startPatrol"
        custom-class="patrol-btn"
      >
        开始巡查
      </van-button>
      
      <van-button 
        wx:else
        type="danger" 
        size="large" 
        icon="stop-circle-o"
        bind:click="endPatrol"
        custom-class="patrol-btn"
      >
        结束巡查
      </van-button>
    </view>
  </view>

  <!-- 日常模块 -->
  <view wx:if="{{ loginUser.roleName != '游客' }}" class="module-card">
    <view class="module-header">日常模块</view>
    <van-grid clickable column-num="4" border="{{ false }}" custom-class="function-grid">
      <!-- 签到 -->
      <van-grid-item 
        icon="/image/manage/checkin.svg" 
        text="签到" 
        link-type="navigateTo"
        url="/subpages/manage/checkin/index"
      />
      
      <!-- 通讯录 -->
      <van-grid-item 
        icon="/image/manage/directory.svg" 
        text="通讯录" 
        link-type="navigateTo"
        url="/subpages/manage/contacts/index"
      />
    </van-grid>
  </view>

  <!-- 景区管理 -->
  <view wx:if="{{ loginUser.roleName != '游客' }}" class="module-card">
    <view class="module-header">景区管理</view>
    <van-grid clickable column-num="4" border="{{ false }}" custom-class="function-grid">
      <!-- 景点信息 -->
      <van-grid-item 
        icon="/image/manage/attraction.svg" 
        text="景点信息" 
        link-type="navigateTo"
        url=""
      />
      
      <!-- 游览路线 -->
      <van-grid-item 
        icon="/image/manage/route.svg" 
        text="游览路线" 
        link-type="navigateTo"
        url=""
      />
      
      <!-- 视频监控 -->
      <van-grid-item 
        icon="/image/manage/camera.svg" 
        text="视频监控" 
        link-type="navigateTo"
        url=""
      />
    </van-grid>
  </view>

  <!-- 加载状态 -->
  <van-loading wx:if="{{ loading }}" type="spinner" color="#1989fa" vertical>
    加载中...
  </van-loading>
</view>