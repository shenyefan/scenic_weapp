<view class="container">
  <van-notify id="van-notify" />
  
  <!-- 搜索框 -->
  <view class="search-container">
    <van-search 
      value="{{ searchValue }}" 
      placeholder="搜索景点名称" 
      bind:change="onSearchChange" 
      bind:search="onSearchConfirm" 
      shape="round" 
      clearable 
      custom-class="search-input" 
      bind:cancel="onSearchCancel">
    </van-search>
  </view>
  
  <!-- 分类标签 -->
  <view class="category-container">
    <view class="category-scroll">
      <view class="category-item {{ activeCategory === 'all' ? 'active' : '' }}" bindtap="onCategoryTap" data-type="all">
        <text>全部</text>
      </view>
      <block wx:for="{{typeList}}" wx:key="id">
        <view class="category-item {{ activeCategory === item.id ? 'active' : '' }}" bindtap="onCategoryTap" data-type="{{item.id}}">
          <text>{{item.typeName}}</text>
        </view>
      </block>
    </view>
  </view>
  
  <!-- 加载状态 -->
  <view wx:if="{{ loading && attractionList.length === 0 }}" class="loading-container">
    <van-loading color="#1989fa" vertical>加载中...</van-loading>
  </view>

  <!-- 地图视图 -->
  <view class="map-container">
    <map id="map" 
         class="map" 
         longitude="{{ mapCenter.longitude }}" 
         latitude="{{ mapCenter.latitude }}" 
         markers="{{ mapMarkers }}" 
         show-location="{{ true }}"
         enable-poi="{{ true }}"
         include-points="{{ includePoints }}"
         show-compass="{{ true }}"
         enable-rotate="{{ true }}"
         enable-zoom="{{ true }}"
         enable-3D="{{ false }}"
         enable-satellite="{{ true }}"
         bindmarkertap="onMarkerTap"
         bindcallouttap="onCalloutTap"
         bindupdated="onMapUpdated"
         enable-cluster="{{ true }}">
    </map>
  </view>

  <!-- 线路推荐按钮 -->
  <view class="float-route-btn" bindtap="onRouteRecommendTap">
    <text>线路推荐</text>
  </view>
</view>