<view class="disposal-list-page">
  <van-notify id="van-notify" />

  <!-- 日期筛选器 -->
  <view class="date-filter-container">
    <van-cell-group>
      <van-cell 
        title="巡查任务日期筛选" 
        value="{{ selectedDateText }}" 
        is-link 
        bind:click="showDatePicker"
        right-icon="calendar-o"
      >
        <van-button 
          wx:if="{{ selectedDate }}" 
          slot="right-icon" 
          type="default" 
          size="mini" 
          bind:click="clearDateFilter"
          custom-style="margin-right: 8px;"
        >
          清除
        </van-button>
      </van-cell>
    </van-cell-group>
  </view>

  <!-- 日期选择器弹窗 -->
  <van-popup 
    show="{{ showDatePickerPopup }}" 
    position="bottom" 
    bind:close="hideDatePicker"
    round
  >
    <van-datetime-picker
      type="date"
      value="{{ currentDate }}"
      min-date="{{ minDate }}"
      max-date="{{ maxDate }}"
      bind:confirm="onDateConfirm"
      bind:cancel="hideDatePicker"
    />
  </van-popup>

  <!-- 加载中 -->
  <view wx:if="{{ loading && disposalList.length === 0 }}" class="loading-container">
    <van-loading size="24px">加载中...</van-loading>
  </view>

  <!-- 问题处置记录列表 -->
  <van-cell-group wx:if="{{ !loading || disposalList.length > 0 }}">
    <van-cell 
        wx:for="{{ disposalList }}" 
        wx:key="id" 
        title-width="70%" 
        title="{{ item.attractionsName || '未知景点' }}"
        label="{{ item.disposerName || '未知' }} {{ item.formattedCreateTime }}"
        value="{{ item.statusText }}"
        value-class="status-{{ item.disposalStatus }}"
        is-link
        bind:click="navigateToEdit"
        data-id="{{ item.id }}"
        data-index="{{ index }}"
    />
  </van-cell-group>
  
  <!-- 加载状态提示 -->
  <view wx:if="{{ disposalList.length > 0 }}" class="loading-view">
    <van-loading wx:if="{{ loading }}" size="24px">加载中...</van-loading>
    <van-divider contentPosition="center" wx:elif="{{ !pageInfo.hasMore }}">没有更多了</van-divider>
  </view>
  
  <!-- 空状态 -->
  <van-empty 
        wx:if="{{ !loading && disposalList.length === 0 }}"
        image="search" 
        description="暂无问题处置记录"
        custom-class="empty-state"
      />
</view>