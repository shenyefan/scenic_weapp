<view class="container">
  <van-notify id="van-notify" />
  
  <!-- 加载状态 -->
  <view wx:if="{{ loading }}" class="loading-container">
    <van-loading color="#1989fa" vertical>加载中...</van-loading>
  </view>
  
  <!-- 编辑表单 -->
  <block wx:else>
    <form bindsubmit="onFormSubmit">
      <van-cell-group inset title="路线信息">
        <!-- 景点选择 -->
        <van-field
          label="选择景点"
          value="{{ selectedAttractions.length > 0 ? selectedAttractions.length + '个景点已选择' : '请选择景点' }}"
          placeholder="请选择景点"
          readonly
          required
          is-link
          bind:tap="showAttractionPopup"
        />
        
        <!-- 已选景点列表 -->
        <view wx:if="{{ selectedAttractions.length > 0 }}" class="selected-attractions">
          <view class="attractions-header">
            <text class="attractions-title">已选景点 ({{ selectedAttractions.length }}个)</text>
            <text class="attractions-tip">拖拽调整顺序</text>
          </view>
          <view class="attractions-list">
            <view 
              wx:for="{{ selectedAttractions }}" 
              wx:key="id" 
              class="attraction-item"
              data-index="{{ index }}"
            >
              <view class="attraction-info">
                <text class="attraction-order">{{ index + 1 }}</text>
                <text class="attraction-name">{{ item.attractionsName }}</text>
              </view>
              <view class="attraction-actions">
                <view 
                  wx:if="{{ index > 0 }}"
                  class="action-btn move-up-btn"
                  bind:tap="moveAttractionUp"
                  data-index="{{ index }}"
                >
                  <van-icon name="arrow-up" size="16" />
                </view>
                <view 
                  wx:if="{{ index < selectedAttractions.length - 1 }}"
                  class="action-btn move-down-btn"
                  bind:tap="moveAttractionDown"
                  data-index="{{ index }}"
                >
                  <van-icon name="arrow-down" size="16" />
                </view>
                <view 
                  class="action-btn delete-btn"
                  bind:tap="removeAttraction"
                  data-index="{{ index }}"
                >
                  <van-icon name="delete-o" size="16" />
                </view>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 路线描述 -->
        <van-field
          label="路线描述"
          name="routeNote"
          value="{{ routeNote }}"
          placeholder="请输入路线描述"
          type="textarea"
          autosize
          bind:input="onRouteNoteInput"
        />
      </van-cell-group>
      
      <!-- 提交按钮 -->
      <view class="button-container">
        <button class="submit-button" form-type="submit" type="primary" loading="{{ submitting }}">保存</button>
        <button wx:if="{{ id }}" class="delete-button" type="danger" bind:tap="showDeleteConfirm" loading="{{ submitting }}">删除</button>
      </view>
      
      <!-- 删除确认弹窗 -->
      <van-dialog
        use-slot
        title="确认删除"
        show="{{ showDeleteConfirm }}"
        show-cancel-button
        confirm-button-text="删除"
        cancel-button-text="取消"
        bind:close="closeDeleteConfirm"
        bind:confirm="confirmDelete"
      >
        <view class="dialog-content">
          确定要删除该路线吗？此操作不可恢复。
        </view>
      </van-dialog>
    </form>
  </block>
  
  <!-- 景点选择弹窗 -->
  <van-popup
    show="{{ showAttractionSelector }}"
    position="bottom"
    round
    bind:close="onAttractionPopupClose"
  >
    <view class="popup-content">
      <view class="popup-header">
        <text class="popup-title">选择景点</text>
        <van-button size="small" type="primary" bind:tap="onAttractionPopupClose">完成</van-button>
      </view>
      <view class="attractions-selector">
        <view 
          wx:for="{{ attractionList }}" 
          wx:key="id" 
          class="selector-item {{ item.selected ? 'selected' : '' }}"
          bind:tap="selectAttraction"
          data-index="{{ index }}"
        >
          <view class="item-info">
            <text class="item-name">{{ item.attractionsName }}</text>
            <text class="item-location">{{ item.attractionsNote || (item.attractionsLat + ', ' + item.attractionsLng) }}</text>
          </view>
          <van-icon wx:if="{{ item.selected }}" name="success" color="#1989fa" />
        </view>
      </view>
    </view>
  </van-popup>
</view>