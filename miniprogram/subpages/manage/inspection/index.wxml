<!-- 全局悬浮定位按钮 -->
<floating-location-btn></floating-location-btn>

<view class="inspection-list-page">
  <van-notify id="van-notify" />

  <!-- 日期筛选器 -->
  <view class="date-filter-container">
    <van-cell-group>
      <van-cell 
        title="筛选日期" 
        value="{{ selectedDateText }}" 
        is-link 
        bind:click="showDatePicker"
        right-icon="calendar-o"
      >
        <van-button 
          wx:if="{{ selectedDate }}" 
          slot="right-icon" 
          type="default" 
          size="mini" 
          bind:click="clearDateFilter"
          custom-style="margin-right: 8px;"
        >
          清除
        </van-button>
      </van-cell>
    </van-cell-group>
  </view>

  <!-- 日期选择器弹窗 -->
  <van-popup 
    show="{{ showDatePickerPopup }}" 
    position="bottom" 
    bind:close="hideDatePicker"
  >
    <van-datetime-picker
      type="date"
      value="{{ currentDate }}"
      min-date="{{ minDate }}"
      max-date="{{ maxDate }}"
      bind:confirm="onDateConfirm"
      bind:cancel="hideDatePicker"
    />
  </van-popup>

  <!-- 加载中 -->
  <view wx:if="{{ loading && inspectionList.length === 0 }}" class="loading-container">
    <van-loading size="24px">加载中...</van-loading>
  </view>

  <!-- 巡查任务列表 -->
  <van-cell-group wx:if="{{ !loading || inspectionList.length > 0 }}">
    <van-cell 
        wx:for="{{ inspectionList }}" 
        wx:key="id" 
        title-width="70%" 
        title="{{ item.attractionsName || '未知景点' }}"
        label="{{ item.taskDate }} {{ item.formattedCreateTime }}"
        value="{{ item.statusText }}"
        value-class="status-{{ item.taskStatus }}"
        is-link
        bind:click="navigateToEdit"
        data-id="{{ item.id }}"
        data-index="{{ index }}"
    >
      <view slot="right-icon" class="task-info">
        <van-tag wx:if="{{ item.isAbnormal }}" type="danger" size="small">异常</van-tag>
        <van-tag wx:else type="success" size="small">正常</van-tag>
      </view>
    </van-cell>
  </van-cell-group>
  
  <!-- 加载状态提示 -->
  <view wx:if="{{ inspectionList.length > 0 }}" class="loading-view">
    <van-loading wx:if="{{ loading }}" size="24px">加载中...</van-loading>
    <van-divider contentPosition="center" wx:elif="{{ !pageInfo.hasMore }}">没有更多了</van-divider>
  </view>
  
  <!-- 空状态 -->
  <van-empty 
        wx:if="{{ !loading && inspectionList.length === 0 }}"
        image="search" 
        description="暂无巡查任务"
        custom-class="empty-state"
      />
</view>