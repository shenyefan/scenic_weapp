<view class="container">
  <van-notify id="van-notify" />
  <!-- 搜索框 -->
  <view class="search-container">
    <van-search value="{{ searchValue }}" placeholder="搜索景点名称" bind:change="onSearchChange" bind:search="onSearchConfirm" shape="round" clearable custom-class="search-input" bind:cancel="onSearchCancel">
    </van-search>
  </view>
  <!-- 加载状态 -->
  <view wx:if="{{ loading && attractionList.length === 0 }}" class="loading-container">
    <van-loading color="#1989fa" vertical>加载中...</van-loading>
  </view>

  <!-- 空状态 -->
  <van-empty wx:elif="{{ !attractionList.length }}" description="暂无景点信息" />

  <!-- 地图视图 -->
  <view wx:elif="{{ viewMode === 'map' }}" class="map-container">
    <map id="map" 
         class="map" 
         longitude="{{ mapCenter.longitude }}" 
         latitude="{{ mapCenter.latitude }}" 
         markers="{{ mapMarkers }}" 
         show-location="{{ true }}"
         enable-poi="{{ true }}"
         include-points="{{ includePoints }}"
         show-compass="{{ true }}"
         enable-rotate="{{ true }}"
         enable-zoom="{{ true }}"
         enable-3D="{{ false }}"
         enable-satellite="{{ true }}"
         bindmarkertap="onMarkerTap"
         bindcallouttap="onCalloutTap"
         bindupdated="onMapUpdated">
    </map>
  </view>

  <!-- 景点列表 -->
  <view wx:else class="attraction-list">
    <van-cell-group wx:for="{{ attractionList }}" wx:key="id">
      <van-cell bind:click="onAttractionTap" data-id="{{ item.id }}" custom-class="attraction-cell">
        <view slot="title" class="attraction-item">
          <view class="attraction-image" wx:if="{{ item.attractionsImg }}">
            <van-image src="{{ item.attractionsImg }}" width="120rpx" height="120rpx" radius="8rpx" fit="cover" />
          </view>
          <view class="attraction-info">
            <view class="attraction-name">{{ item.attractionsName || '未命名景点' }}</view>
            <view class="attraction-inspector">巡查员：{{ item.inspectorName || '未分配' }}</view>
            <view class="attraction-types">
              <van-tag wx:for="{{ item.attractionsTypes }}" wx:key="id" wx:for-item="typeItem" type="primary" size="mini" plain>
                {{ typeItem.typeName }}
              </van-tag>
              <text wx:if="{{ !item.attractionsTypes || item.attractionsTypes.length === 0 }}" class="no-type">暂无分类</text>
            </view>
          </view>
        </view>
      </van-cell>
    </van-cell-group>

    <!-- 加载状态提示 -->
    <view class="loading-view">
      <van-loading wx:if="{{ loading }}" size="24px">加载中...</van-loading>
      <!-- 没有更多数据提示 -->
      <van-divider contentPosition="center" wx:elif="{{ attractionList.length > 0 && !pageInfo.hasMore }}">没有更多了</van-divider>
    </view>
  </view>

  <!-- 悬浮切换视图按钮 -->
  <view class="float-toggle-btn" bind:tap="toggleViewMode">
    <van-icon name="{{ viewMode === 'list' ? 'location-o' : 'bars' }}" size="24px" />
    <text>{{ viewMode === 'list' ? '地图' : '列表' }}</text>
  </view>
  
  <!-- 新增悬浮按钮 -->
  <view class="float-add-btn" bind:tap="onAddAttractionTap">
    <van-icon name="plus" size="24px" />
    <text>新增</text>
  </view>
</view>