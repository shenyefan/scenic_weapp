<view class="container">
  <!-- 日期筛选器 -->
  <view class="date-filter-container">
    <van-cell-group>
      <van-cell 
        title="订单日期筛选" 
        value="{{ selectedDateText }}" 
        is-link 
        bind:click="showDatePicker"
        right-icon="calendar-o"
      >
        <van-button 
          wx:if="{{ selectedDate }}" 
          slot="right-icon" 
          type="default" 
          size="mini" 
          bind:click="clearDateFilter"
          custom-style="margin-right: 8px;"
        >
          清除
        </van-button>
      </van-cell>
    </van-cell-group>
  </view>

  <!-- 日期选择器弹窗 -->
  <van-popup 
    show="{{ showDatePickerPopup }}" 
    position="bottom" 
    bind:close="hideDatePicker"
    round
  >
    <van-datetime-picker
      type="date"
      value="{{ currentDate }}"
      min-date="{{ minDate }}"
      max-date="{{ maxDate }}"
      bind:confirm="onDateConfirm"
      bind:cancel="hideDatePicker"
    />
  </van-popup>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <van-loading size="24px" vertical>加载中...</van-loading>
  </view>

  <!-- 订单列表 -->
  <view wx:else class="order-list">
    <view wx:if="{{orderList.length === 0}}" class="empty-container">
      <van-empty description="暂无订单" />
    </view>
    
    <view wx:else>
      <view wx:for="{{orderList}}" wx:key="id" class="order-item" bind:tap="onViewDetail" data-order="{{item}}">
        <van-cell-group>
          <!-- 订单编号和状态 -->
          <van-cell>
            <view slot="title" class="order-header">
              <text class="order-id">游览日期：{{item.formattedVisitDate}}</text>
              <van-tag 
                type="{{item.paymentStatus === 1 ? 'success' : item.paymentStatus === 0 ? 'warning' : item.paymentStatus === 2 ? 'primary' : item.paymentStatus === 4 ? 'danger' : item.paymentStatus === 3 ? 'danger' : 'default'}}"
                size="medium"
              >
                {{item.paymentStatus === 0 ? '待支付' : item.paymentStatus === 1 ? '已支付' : item.paymentStatus === 2 ? '已完成' : item.paymentStatus === 3 ? '已取消' : item.paymentStatus === 4 ? '已退款' : '未知状态'}}
              </van-tag>
            </view>
          </van-cell>
          
          <!-- 门票信息 -->
          <van-cell title="门票信息" value="{{item.formattedTicketInfo}}" />

          <!-- 总金额 -->
          <van-cell title="总金额" value="¥{{item.totalPrice}}" />
          
          <!-- 联系人信息 -->
          <van-cell title="联系人" value="{{item.contactName}}" />
          
          <!-- 联系电话 -->
          <van-cell title="联系电话" value="{{item.contactPhone}}" />
          
          <!-- 订单编号 -->
          <van-cell title="订单编号" value="{{item.id}}" />
        </van-cell-group>
      </view>
    </view>
  </view>
</view>