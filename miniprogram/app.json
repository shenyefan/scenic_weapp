    {
      "root": "subpages/user",
      "name": "user",
      "pages": [
        "info/index"
      ]
    },
    {
      "root": "subpages/manage",
      "name": "manage",
      "pages": [
        "checkin/index",
        "checkin_history/index",
        "contacts/index",
        "attractions/index",
        "attractions_edit/index",
        "routes/index",
        "routes_edit/index",
        "track/index",
        "disposal/index",
        "disposal_edit/index",
        "inspection/index",
        "inspection_edit/index",
        "inspection_map/index"
      ]
    }
